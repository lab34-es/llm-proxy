{{define "content"}}
<h2>API Keys</h2>

{{if .NewKey}}
<article>
  <header><strong>New API Key Created</strong></header>
  <p>Copy this key now. It will not be shown again.</p>
  <div class="key-display" id="new-key">{{.NewKey}}</div>
  <button class="outline" onclick="navigator.clipboard.writeText(document.getElementById('new-key').textContent.trim())">
    Copy to Clipboard
  </button>
</article>
{{end}}

<details {{if not .Keys}}open{{end}}>
  <summary role="button" class="outline">Create API Key</summary>
  <form method="POST" action="/dashboard/keys">
    <div class="grid">
      <label>
        Name
        <input type="text" name="name" placeholder="e.g. my-app-prod" required>
      </label>
      <label>
        Provider
        <select name="provider_id" required>
          <option value="">Select a provider...</option>
          {{range .Providers}}
          <option value="{{.ID}}">{{.Name}}</option>
          {{end}}
        </select>
      </label>
    </div>
    <label>
      Rate Limit (requests/min, 0 = unlimited)
      <input type="number" name="rate_limit_rpm" value="60" min="0">
    </label>
    <button type="submit">Create Key</button>
  </form>
</details>

{{if .Keys}}
<figure>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Provider</th>
      <th>RPM Limit</th>
      <th>Status</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {{range .Keys}}
    <tr>
      <td class="mono">{{shortID .ID}}</td>
      <td>{{.Name}}</td>
      <td class="mono">{{shortID .ProviderID}}</td>
      <td class="text-right">{{if eq .RateLimitRPM 0}}unlimited{{else}}{{.RateLimitRPM}}{{end}}</td>
      <td>
        {{if isRevoked .RevokedAt}}
          <span class="badge badge-revoked">Revoked</span>
        {{else}}
          <span class="badge badge-active">Active</span>
        {{end}}
      </td>
      <td>{{formatTime .CreatedAt}}</td>
      <td class="actions">
        {{if not (isRevoked .RevokedAt)}}
        <form method="POST" action="/dashboard/keys/{{.ID}}/revoke" style="display:inline"
              onsubmit="return confirm('Revoke key {{.Name}}? This cannot be undone.')">
          <button type="submit" class="outline secondary" style="padding:0.25rem 0.75rem;margin:0">Revoke</button>
        </form>
        {{end}}
      </td>
    </tr>
    {{end}}
  </tbody>
</table>
</figure>
{{else}}
<p>No API keys created yet. Create one above.</p>
{{end}}
{{end}}
