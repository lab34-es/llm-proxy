{{define "login"}}<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — LLM Proxy</title>
  <link rel="stylesheet" href="/dashboard/static/pico.min.css">
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-card { width: 100%; max-width: 400px; }
    .flash-error { background: var(--pico-del-color); padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <article class="login-card">
    <header>
      <h2>LLM Proxy Dashboard</h2>
    </header>
    {{if .Error}}<div class="flash-error">{{.Error}}</div>{{end}}
    <form method="POST" action="/dashboard/login">
      <label for="token">Admin Token</label>
      <input type="password" id="token" name="token" placeholder="Enter your admin token" required autofocus>
      <button type="submit">Sign In</button>
    </form>
  </article>
</body>
</html>{{end}}
