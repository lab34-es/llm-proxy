{{define "content"}}
<h2>Playground</h2>

<div class="grid">
  <label>
    API Key
    <input type="password" id="pg-key" placeholder="llmp-... (paste your proxy API key)">
    <small>Paste a proxy API key. You can create one in the <a href="/dashboard/keys">API Keys</a> page.</small>
  </label>
  <label>
    Model
    <input type="text" id="pg-model" placeholder="e.g. gpt-4o, gpt-3.5-turbo" value="gpt-4o">
  </label>
</div>

<label>
  System Prompt (optional)
  <textarea id="pg-system" rows="2" placeholder="You are a helpful assistant."></textarea>
</label>

<div id="pg-messages" style="border:1px solid var(--pico-muted-border-color);border-radius:8px;padding:1rem;min-height:200px;max-height:500px;overflow-y:auto;margin-bottom:1rem;background:var(--pico-code-background-color);">
  <p style="color:var(--pico-muted-color)">Send a message to start a conversation.</p>
</div>

<form id="pg-form" onsubmit="return false;">
  <div class="grid" style="grid-template-columns:1fr auto auto;">
    <input type="text" id="pg-input" placeholder="Type your message..." autocomplete="off">
    <button type="submit" id="pg-send">Send</button>
    <button type="button" id="pg-clear" class="outline secondary">Clear</button>
  </div>
</form>
{{end}}
